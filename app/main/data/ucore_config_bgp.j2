{# =============================生成配置前需要先给如下变量赋值================================== #}
{%- set edge_datacenter = 'XXX1' %}
{%- set edge_az_community = 'XXX2' %}
{%- set edge_az_intranet_community = 'XXX3' %}
{%- set veedge_az_community = 'XXX4' %}
{%- set edgepe_asn = 'XXX5' %}
{%- set ucore_region_community = 'XXX6' %}
{%- set ucore_az_community = 'XXX7' %}
{# =============================config community&prefix-list========================================= #}
ip prefix-list PL_INTER_SUMMARY_V4 index 10 permit 10.0.0.0 8
ipv6 prefix-list PL_INTER_SUMMARY_V6 index 10 permit FDBD:: 16
#
ip community-list basic CL_EDGEPOP_{{edge_datacenter}} permit {{edge_az_community}}
ip community-list basic CL_EDGEPOP_{{edge_datacenter}}_INTRANET permit {{edge_az_intranet_community}}
#
ip prefix-list PL_FAKEINTERNET_SUMMARY_V4 index 10 permit 30.130.0.0 16 less-equal 24
ipv6 prefix-list PL_FAKEINTERNET_SUMMARY_V6 index 10 permit 2406:D440:FE00:: 40 less-equal 56
#
ip community-list basic CL_CORE_DC_TAG permit 65520:11000
ip community-list basic CL_CORE_DC_TAG permit 65520:11001
ip community-list basic CL_CORE_DC_TAG permit 65520:5
ip community-list basic CL_CORE_DC_TAG permit 65520:6
ip community-list basic CL_CORE_DC_TAG permit 65520:7
#
{# =============================global policy========================================= #}
route-policy FROM_{{edge_datacenter}}_EDGEPE_V4 permit node 10
if-match community name CL_EDGEPOP_{{edge_datacenter}}
apply community {{ucore_region_community}} {{ucore_az_community}} 65520:7 additive
apply local-preference 690
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_V4 deny node 1000
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_V6 permit node 10
if-match community name CL_EDGEPOP_{{edge_datacenter}}
apply community {{ucore_region_community}} {{ucore_az_community}} 65520:7 additive
apply local-preference 690
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_V6 deny node 1000
#
route-policy TO_{{edge_datacenter}}_EDGEPE_V4 permit node 10
if-match ip address prefix-list PL_INTER_SUMMARY_V4
#
route-policy TO_{{edge_datacenter}}_EDGEPE_V4 permit node 20
if-match ip address prefix-list PL_FAKEINTERNET_SUMMARY_V4
#
route-policy TO_{{edge_datacenter}}_EDGEPE_V4 permit node 30
if-match community name CL_CORE_DC_TAG
#
route-policy TO_{{edge_datacenter}}_EDGEPE_V4 deny node 1000
#
route-policy TO_{{edge_datacenter}}_EDGEPE_V6 permit node 10
if-match ipv6 address prefix-list PL_INTER_SUMMARY_V6
#
route-policy TO_{{edge_datacenter}}_EDGEPE_V6 permit node 20
if-match ipv6 address prefix-list PL_FAKEINTERNET_SUMMARY_V6
#
route-policy TO_{{edge_datacenter}}_EDGEPE_V6 permit node 30
if-match community name CL_CORE_DC_TAG
#
route-policy TO_{{edge_datacenter}}_EDGEPE_V6 deny node 1000
#
{# =============================vpn10 policy========================================= #}
route-policy FROM_{{edge_datacenter}}_EDGEPE_INTRANET_V4 permit node 10
if-match community name CL_EDGEPOP_{{edge_datacenter}}_INTRANET
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_INTRANET_V4 deny node 1000
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_INTRANET_V6 permit node 10
if-match community name CL_EDGEPOP_{{edge_datacenter}}_INTRANET
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_INTRANET_V6 deny node 1000
#
route-policy TO_{{edge_datacenter}}_EDGEPE_INTRANET_V4 permit node 10
#
route-policy TO_{{edge_datacenter}}_EDGEPE_INTRANET_V4 deny node 1000
#
route-policy TO_{{edge_datacenter}}_EDGEPE_INTRANET_V6 permit node 10
#
route-policy TO_{{edge_datacenter}}_EDGEPE_INTRANET_V6 deny node 1000
#
{# =============================tob_dcn policy========================================= #}
ip community-list basic CL_EDGEPOP_TOB_DCN_{{edge_datacenter}} permit {{veedge_az_community}}
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_TOB_DCN_V4 permit node 10
if-match community name CL_EDGEPOP_TOB_DCN_{{edge_datacenter}}
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_TOB_DCN_V4 deny node 1000
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_TOB_DCN_V6 permit node 10
if-match community name CL_EDGEPOP_TOB_DCN_{{edge_datacenter}}
#
route-policy FROM_{{edge_datacenter}}_EDGEPE_TOB_DCN_V6 deny node 1000
#
route-policy TO_{{edge_datacenter}}_EDGEPE_TOB_DCN_V4 permit node 10
#
route-policy TO_{{edge_datacenter}}_EDGEPE_TOB_DCN_V4 deny node 1000
#
route-policy TO_{{edge_datacenter}}_EDGEPE_TOB_DCN_V6 permit node 10
#
route-policy TO_{{edge_datacenter}}_EDGEPE_TOB_DCN_V6 deny node 1000
#
{# =============================bgp config========================================= #}
bgp 137718
group {{edge_datacenter}}_EDGEPE_V4 external
peer {{edge_datacenter}}_EDGEPE_V4 as-number {{edgepe_asn}}
peer {{edge_datacenter}}_EDGEPE_V4 route-update-interval 0
group {{edge_datacenter}}_EDGEPE_V6 external
peer {{edge_datacenter}}_EDGEPE_V6 as-number {{edgepe_asn}}
peer {{edge_datacenter}}_EDGEPE_V6 route-update-interval 0
address-family ipv4 unicast
peer {{edge_datacenter}}_EDGEPE_V4 enable
y
peer {{edge_datacenter}}_EDGEPE_V4 route-policy FROM_{{edge_datacenter}}_EDGEPE_V4 import
peer {{edge_datacenter}}_EDGEPE_V4 route-policy TO_{{edge_datacenter}}_EDGEPE_V4 export
peer {{edge_datacenter}}_EDGEPE_V4 advertise-community
peer {{edge_datacenter}}_EDGEPE_V4 advertise-ext-community
peer {{edge_datacenter}}_EDGEPE_V4 keep-all-routes
#
address-family ipv6 unicast
peer {{edge_datacenter}}_EDGEPE_V6 enable
y
peer {{edge_datacenter}}_EDGEPE_V6 route-policy FROM_{{edge_datacenter}}_EDGEPE_V6 import
peer {{edge_datacenter}}_EDGEPE_V6 route-policy TO_{{edge_datacenter}}_EDGEPE_V6 export
peer {{edge_datacenter}}_EDGEPE_V6 advertise-community
peer {{edge_datacenter}}_EDGEPE_V6 advertise-ext-community
peer {{edge_datacenter}}_EDGEPE_V6 keep-all-routes
#
bgp 137718
ip vpn-instance TI-VPN10-Intranet
timer keepalive 10 hold 30
group {{edge_datacenter}}_EDGEPE_INTRANET_V4 external
peer {{edge_datacenter}}_EDGEPE_INTRANET_V4 as-number {{edgepe_asn}}
peer {{edge_datacenter}}_EDGEPE_INTRANET_V4 route-update-interval 0
group {{edge_datacenter}}_EDGEPE_INTRANET_V6 external
peer {{edge_datacenter}}_EDGEPE_INTRANET_V6 as-number {{edgepe_asn}}
peer {{edge_datacenter}}_EDGEPE_INTRANET_V6 route-update-interval 0
address-family ipv4 unicast
balance 128
balance as-path-relax ebgp
preference 200 200 200
peer {{edge_datacenter}}_EDGEPE_INTRANET_V4 enable
y
peer {{edge_datacenter}}_EDGEPE_INTRANET_V4 route-policy FROM_{{edge_datacenter}}_EDGEPE_INTRANET_V4 import
peer {{edge_datacenter}}_EDGEPE_INTRANET_V4 route-policy TO_{{edge_datacenter}}_EDGEPE_INTRANET_V4 export
peer {{edge_datacenter}}_EDGEPE_INTRANET_V4 advertise-community
peer {{edge_datacenter}}_EDGEPE_INTRANET_V4 advertise-ext-community
peer {{edge_datacenter}}_EDGEPE_INTRANET_V4 keep-all-routes
#
address-family ipv6 unicast
balance 128
balance as-path-relax ebgp
preference 200 200 200
peer {{edge_datacenter}}_EDGEPE_INTRANET_V6 enable
y
peer {{edge_datacenter}}_EDGEPE_INTRANET_V6 route-policy FROM_{{edge_datacenter}}_EDGEPE_INTRANET_V6 import
peer {{edge_datacenter}}_EDGEPE_INTRANET_V6 route-policy TO_{{edge_datacenter}}_EDGEPE_INTRANET_V6 export
peer {{edge_datacenter}}_EDGEPE_INTRANET_V6 advertise-community
peer {{edge_datacenter}}_EDGEPE_INTRANET_V6 advertise-ext-community
peer {{edge_datacenter}}_EDGEPE_INTRANET_V6 keep-all-routes
#
bgp 137718
ip vpn-instance TOB-DCN
timer keepalive 10 hold 30
group {{edge_datacenter}}_EDGEPE_TOB_DCN_V4 external
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V4 as-number {{edgepe_asn}}
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V4 route-update-interval 0
group {{edge_datacenter}}_EDGEPE_TOB_DCN_V6 external
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V6 as-number {{edgepe_asn}}
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V6 route-update-interval 0
address-family ipv4 unicast
balance 128
balance as-path-relax
preference 200 200 200
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V4 enable
y
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V4 route-policy FROM_{{edge_datacenter}}_EDGEPE_TOB_DCN_V4 import
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V4 route-policy TO_{{edge_datacenter}}_EDGEPE_TOB_DCN_V4 export
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V4 advertise-community
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V4 advertise-ext-community
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V4 keep-all-routes
#
address-family ipv6 unicast
balance 128
balance as-path-relax
preference 200 200 200
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V6 enable
y
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V6 route-policy FROM_{{edge_datacenter}}_EDGEPE_TOB_DCN_V6 import
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V6 route-policy TO_{{edge_datacenter}}_EDGEPE_TOB_DCN_V6 export
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V6 advertise-community
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V6 advertise-ext-community
peer {{edge_datacenter}}_EDGEPE_TOB_DCN_V6 keep-all-routes
#
{# =============================bgp_peers config========================================= #}
{% for device_name, device_links in devices.items() %}
{% if 'UCORE' in device_name %}
{{device_name}}
{%- for link in device_links %}
{%- set peer_ipv4_addr = link.peer_ipv4.split('/')[0] %}
{%- set peer_ipv6_addr = link.peer_ipv6.split('/')[0] %}
{%- if link.local_vpn == "none" and link.type == 'bundle' %}
bgp 137718
peer {{peer_ipv4_addr}} group {{edge_datacenter}}_EDGEPE_V4
y
peer {{peer_ipv6_addr}} group {{edge_datacenter}}_EDGEPE_V6
y
#
{%- elif link.local_vpn == "TI-VPN10-Intranet" %}
bgp 137718
ip vpn-instance TI-VPN10-Intranet
peer {{peer_ipv4_addr}} group {{edge_datacenter}}_EDGEPE_INTRANET_V4
y
peer {{peer_ipv6_addr}} group {{edge_datacenter}}_EDGEPE_INTRANET_V6
y
#
{%- elif link.local_vpn == "TOB-DCN" %}
bgp 137718
ip vpn-instance TOB-DCN
peer {{peer_ipv4_addr}} group {{edge_datacenter}}_EDGEPE_TOB_DCN_V4
y
peer {{peer_ipv6_addr}} group {{edge_datacenter}}_EDGEPE_TOB_DCN_V6
y
#
{%- endif %}
{%- endfor %}
{%- endif %}
{%- endfor %}